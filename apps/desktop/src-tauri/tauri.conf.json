{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Joudo",
  "version": "0.1.0",
  "identifier": "dev.joudo.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "beforeBundleCommand": "pnpm prepare:bundle-runtime",
    "devUrl": "http://127.0.0.1:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Joudo",
        "width": 440,
        "height": 580,
        "visible": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "createUpdaterArtifacts": false,
    "resources": {
      "bundle-resources/": ""
    },
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
