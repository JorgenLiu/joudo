{
  "name": "joudo",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @joudo/bridge --filter @joudo/web dev",
    "dev:bridge": "corepack pnpm --filter @joudo/bridge dev",
    "dev:web": "corepack pnpm --filter @joudo/web dev",
    "dev:desktop": "corepack pnpm --filter @joudo/desktop tauri:dev",
    "validate:policy-live": "node scripts/validate-policy-live.mjs",
    "typecheck": "corepack pnpm --recursive --filter @joudo/shared --filter @joudo/bridge --filter @joudo/web typecheck",
    "build": "corepack pnpm typecheck && corepack pnpm --filter @joudo/web build && corepack pnpm --filter @joudo/bridge build",
    "build:desktop": "corepack pnpm --filter @joudo/desktop tauri:build",
    "start": "corepack pnpm --filter @joudo/bridge start"
  }
}
